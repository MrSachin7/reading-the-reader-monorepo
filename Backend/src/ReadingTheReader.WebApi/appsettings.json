{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RealtimePersistence": {
    "Provider": "File",
    "ActiveReplayDirectoryPath": "./data/live-experiments",
    "ReplayExportFilePath": "./data/latest/experiment-session-export.json",
    "SavedReplayExportsDirectoryPath": "./data/saved-exports",
    "ActiveReplaySaveIntervalMilliseconds": 10000
  },
  "ReadingMaterialSetupStorage": {
    "DirectoryPath": "./data/reading-material-setups"
  },
  "Calibration": {
    "PresetPointCount":16
  }
}
