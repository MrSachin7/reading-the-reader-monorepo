{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RealtimePersistence": {
    "Provider": "File",
    "ActiveReplayDirectoryPath": "./data/live-experiments",
    "ReplayExportFilePath": "./data/latest/experiment-session-export.json",
    "SavedReplayExportsDirectoryPath": "./data/saved-files",
    "ReplayRecoveryDirectoryPath": "./data/experiment-replay-recovery",
    "ActiveReplaySaveIntervalMilliseconds": 10000,
    "ReplayRecoveryFlushIntervalMilliseconds": 5000
  },
  "ReadingMaterialSetupStorage": {
    "DirectoryPath": "./data/reading-material-setups"
  },
  "Calibration": {
    "PresetPointCount": 16
  },
  "ExternalProvider": {
    "SharedSecret": "change-me-local-provider-secret",
    "HeartbeatTimeoutMilliseconds": 15000
  }
}
